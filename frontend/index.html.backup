<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GrantFlow — Transparent Fund Tracking</title>
    <script src="https://cdn.jsdelivr.net/npm/algosdk@2.7.0/dist/algosdk.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <style>
         :root {
            --cream: #faf8f4;
            --white: #ffffff;
            --sky: #e8f4fd;
            --blue-light: #d0e8f8;
            --blue: #4a9edd;
            --blue-deep: #2d7fc4;
            --mint: #d6f0ea;
            --mint-dark: #3cb89a;
            --gold: #e8c96a;
            --text: #1a2332;
            --text-mid: #4a5568;
            --text-soft: #8898a8;
            --border: rgba(74, 158, 221, 0.18);
            --glass: rgba(255, 255, 255, 0.65);
            --glass-strong: rgba(255, 255, 255, 0.85);
            --shadow: 0 8px 32px rgba(45, 127, 196, 0.10);
            --shadow-lg: 0 20px 60px rgba(45, 127, 196, 0.15);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
        }
        /* Background */
        
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 80% 60% at 10% 0%, rgba(208, 232, 248, 0.55) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 90% 30%, rgba(214, 240, 234, 0.45) 0%, transparent 55%), radial-gradient(ellipse 40% 40% at 50% 80%, rgba(232, 201, 106, 0.12) 0%, transparent 50%), var(--cream);
            z-index: 0;
            pointer-events: none;
        }
        
        body>* {
            position: relative;
            z-index: 1;
        }
        /* NAV */
        
        nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 18px 40px;
            background: var(--glass-strong);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-family: 'DM Serif Display', serif;
            font-size: 1.4rem;
            color: var(--text);
            text-decoration: none;
        }
        
        .logo-icon {
            width: 34px;
            height: 34px;
            background: linear-gradient(135deg, var(--blue), var(--mint-dark));
            border-radius: 10px;
            display: grid;
            place-items: center;
            font-size: 16px;
        }
        
        .nav-links {
            display: flex;
            gap: 8px;
        }
        
        .nav-link {
            padding: 7px 16px;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text-mid);
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            background: transparent;
        }
        
        .nav-link:hover,
        .nav-link.active {
            background: var(--glass);
            color: var(--blue-deep);
            box-shadow: var(--shadow);
        }
        
        .nav-cta {
            padding: 8px 20px;
            border-radius: 8px;
            background: linear-gradient(135deg, var(--blue), var(--blue-deep));
            color: white;
            font-size: 0.875rem;
            font-weight: 500;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 4px 14px rgba(74, 158, 221, 0.35);
        }
        
        .nav-cta:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(74, 158, 221, 0.45);
        }
        
        .wallet-btn {
            padding: 8px 16px;
            border-radius: 8px;
            background: rgba(59, 184, 154, 0.15);
            color: var(--mint-dark);
            border: 1px solid rgba(59, 184, 154, 0.3);
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .wallet-btn:hover {
            background: rgba(59, 184, 154, 0.25);
        }
        
        .wallet-btn.connected {
            background: rgba(59, 184, 154, 0.2);
        }
        /* HERO */
        
        .hero {
            padding: 80px 40px 60px;
            text-align: center;
            max-width: 760px;
            margin: 0 auto;
        }
        
        .hero-tag {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 14px;
            border-radius: 20px;
            background: var(--glass-strong);
            border: 1px solid var(--border);
            font-size: 0.78rem;
            font-weight: 500;
            color: var(--blue-deep);
            margin-bottom: 24px;
            backdrop-filter: blur(10px);
        }
        
        .hero-tag span {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--mint-dark);
            display: block;
            animation: pulse 2s infinite;
        }
        
        @keyframes pulse {
            0%,
            100% {
                opacity: 1;
                transform: scale(1)
            }
            50% {
                opacity: 0.5;
                transform: scale(1.3)
            }
        }
        
        .hero h1 {
            font-family: 'DM Serif Display', serif;
            font-size: clamp(2.4rem, 5vw, 3.4rem);
            line-height: 1.18;
            color: var(--text);
            margin-bottom: 20px;
        }
        
        .hero h1 em {
            font-style: italic;
            color: var(--blue-deep);
        }
        
        .hero p {
            font-size: 1.05rem;
            color: var(--text-mid);
            font-weight: 300;
            max-width: 560px;
            margin: 0 auto 36px;
            line-height: 1.7;
        }
        
        .hero-actions {
            display: flex;
            gap: 12px;
            justify-content: center;
            flex-wrap: wrap;
        }
        
        .btn-primary {
            padding: 12px 28px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--blue), var(--blue-deep));
            color: white;
            font-size: 0.9rem;
            font-weight: 500;
            border: none;
            cursor: pointer;
            box-shadow: 0 6px 20px rgba(74, 158, 221, 0.35);
            transition: all 0.2s;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(74, 158, 221, 0.45);
        }
        
        .btn-primary:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .btn-secondary {
            padding: 12px 28px;
            border-radius: 10px;
            background: var(--glass-strong);
            color: var(--text);
            font-size: 0.9rem;
            font-weight: 500;
            border: 1px solid var(--border);
            cursor: pointer;
            backdrop-filter: blur(10px);
            transition: all 0.2s;
        }
        
        .btn-secondary:hover {
            background: white;
            box-shadow: var(--shadow);
        }
        /* STATS BAR */
        
        .stats-bar {
            display: flex;
            gap: 0;
            justify-content: center;
            max-width: 900px;
            margin: 0 auto 60px;
            padding: 0 40px;
        }
        
        .stat-item {
            flex: 1;
            text-align: center;
            padding: 20px 24px;
            background: var(--glass);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid var(--border);
            transition: all 0.2s;
        }
        
        .stat-item:first-child {
            border-radius: 14px 0 0 14px;
        }
        
        .stat-item:last-child {
            border-radius: 0 14px 14px 0;
        }
        
        .stat-item:hover {
            background: var(--glass-strong);
        }
        
        .stat-val {
            font-family: 'DM Serif Display', serif;
            font-size: 1.8rem;
            color: var(--text);
        }
        
        .stat-label {
            font-size: 0.78rem;
            color: var(--text-soft);
            font-weight: 500;
            margin-top: 2px;
        }
        /* MAIN CONTENT */
        
        .main {
            max-width: 1160px;
            margin: 0 auto;
            padding: 0 40px 80px;
        }
        /* SECTION TITLE */
        
        .section-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.5rem;
            color: var(--text);
            margin-bottom: 6px;
        }
        
        .section-sub {
            font-size: 0.875rem;
            color: var(--text-soft);
            margin-bottom: 24px;
        }
        /* GRANT CARDS */
        
        .grants-section {
            margin-bottom: 48px;
        }
        
        .grants-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 18px;
        }
        
        .grant-card {
            background: var(--glass-strong);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            transition: all 0.25s;
            cursor: pointer;
        }
        
        .grant-card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
            background: white;
            border-color: rgba(74, 158, 221, 0.3);
        }
        
        .grant-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 14px;
        }
        
        .grant-badge {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }
        
        .badge-active {
            background: rgba(59, 184, 154, 0.15);
            color: var(--mint-dark);
            border: 1px solid rgba(59, 184, 154, 0.3);
        }
        
        .badge-pending {
            background: rgba(232, 201, 106, 0.2);
            color: #b8960a;
            border: 1px solid rgba(232, 201, 106, 0.4);
        }
        
        .badge-completed {
            background: rgba(74, 158, 221, 0.15);
            color: var(--blue-deep);
            border: 1px solid var(--border);
        }
        
        .grant-amount {
            font-family: 'DM Serif Display', serif;
            font-size: 1.4rem;
            color: var(--text);
        }
        
        .grant-title {
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 6px;
        }
        
        .grant-team {
            font-size: 0.82rem;
            color: var(--text-soft);
            margin-bottom: 16px;
        }
        
        .milestones-mini {
            display: flex;
            gap: 6px;
            margin-bottom: 16px;
        }
        
        .ms-dot {
            flex: 1;
            height: 5px;
            border-radius: 3px;
            transition: all 0.3s;
        }
        
        .ms-dot.done {
            background: var(--mint-dark);
        }
        
        .ms-dot.active {
            background: var(--gold);
            animation: shimmer 1.5s infinite;
        }
        
        .ms-dot.pending {
            background: var(--blue-light);
        }
        
        @keyframes shimmer {
            0%,
            100% {
                opacity: 1
            }
            50% {
                opacity: 0.5
            }
        }
        
        .grant-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .grant-progress-text {
            font-size: 0.8rem;
            color: var(--text-mid);
        }
        
        .grant-progress-text strong {
            color: var(--text);
        }
        
        .grant-action {
            font-size: 0.8rem;
            font-weight: 500;
            color: var(--blue);
            background: rgba(74, 158, 221, 0.1);
            padding: 4px 12px;
            border-radius: 6px;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .grant-action:hover {
            background: rgba(74, 158, 221, 0.2);
        }
        /* DETAIL PANEL */
        
        .panel-overlay {
            position: fixed;
            inset: 0;
            z-index: 200;
            background: rgba(26, 35, 50, 0.35);
            backdrop-filter: blur(6px);
            -webkit-backdrop-filter: blur(6px);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }
        
        .panel-overlay.open {
            opacity: 1;
            pointer-events: all;
        }
        
        .side-panel {
            position: fixed;
            top: 0;
            right: 0;
            bottom: 0;
            width: 440px;
            max-width: 100vw;
            background: rgba(250, 248, 244, 0.97);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            border-left: 1px solid var(--border);
            box-shadow: -20px 0 60px rgba(45, 127, 196, 0.12);
            overflow-y: auto;
            transform: translateX(100%);
            transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            z-index: 201;
            padding: 32px;
        }
        
        .side-panel.open {
            transform: translateX(0);
        }
        
        .panel-close {
            position: absolute;
            top: 20px;
            right: 20px;
            width: 32px;
            height: 32px;
            border-radius: 8px;
            background: var(--glass);
            border: 1px solid var(--border);
            cursor: pointer;
            font-size: 16px;
            color: var(--text-mid);
            display: grid;
            place-items: center;
            transition: all 0.2s;
        }
        
        .panel-close:hover {
            background: white;
            color: var(--text);
        }
        
        .panel-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.4rem;
            color: var(--text);
            margin-bottom: 4px;
            margin-right: 40px;
        }
        
        .panel-sub {
            font-size: 0.82rem;
            color: var(--text-soft);
            margin-bottom: 24px;
        }
        
        .panel-amount-block {
            background: linear-gradient(135deg, rgba(208, 232, 248, 0.6), rgba(214, 240, 234, 0.4));
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .panel-amount {
            font-family: 'DM Serif Display', serif;
            font-size: 2rem;
            color: var(--text);
        }
        
        .panel-released {
            font-size: 0.8rem;
            color: var(--text-soft);
        }
        
        .panel-released strong {
            color: var(--mint-dark);
        }
        /* MILESTONES */
        
        .milestones-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 24px;
        }
        
        .milestone-row {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            border-radius: 12px;
            background: var(--glass);
            border: 1px solid var(--border);
            transition: all 0.2s;
        }
        
        .milestone-row.done {
            background: rgba(59, 184, 154, 0.06);
            border-color: rgba(59, 184, 154, 0.25);
        }
        
        .milestone-row.current {
            background: rgba(232, 201, 106, 0.08);
            border-color: rgba(232, 201, 106, 0.3);
        }
        
        .ms-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            flex-shrink: 0;
            display: grid;
            place-items: center;
            font-size: 14px;
        }
        
        .ms-icon.done {
            background: rgba(59, 184, 154, 0.15);
        }
        
        .ms-icon.current {
            background: rgba(232, 201, 106, 0.2);
        }
        
        .ms-icon.pending {
            background: rgba(74, 158, 221, 0.1);
        }
        
        .ms-info {
            flex: 1;
        }
        
        .ms-name {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text);
        }
        
        .ms-date {
            font-size: 0.75rem;
            color: var(--text-soft);
        }
        
        .ms-amount {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-mid);
        }
        
        .approve-btn {
            padding: 5px 12px;
            border-radius: 7px;
            font-size: 0.78rem;
            font-weight: 500;
            background: linear-gradient(135deg, var(--blue), var(--blue-deep));
            color: white;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: 0 2px 8px rgba(74, 158, 221, 0.3);
        }
        
        .approve-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(74, 158, 221, 0.4);
        }
        
        .approve-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        /* TX FEED */
        
        .tx-section {
            margin-bottom: 48px;
        }
        
        .tx-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        
        .tx-row {
            display: flex;
            align-items: center;
            gap: 16px;
            padding: 14px 18px;
            border-radius: 12px;
            background: var(--glass);
            border: 1px solid var(--border);
            transition: all 0.2s;
        }
        
        .tx-row:hover {
            background: var(--glass-strong);
            box-shadow: var(--shadow);
        }
        
        .tx-icon {
            width: 38px;
            height: 38px;
            border-radius: 10px;
            flex-shrink: 0;
            display: grid;
            place-items: center;
            font-size: 15px;
        }
        
        .tx-icon.release {
            background: rgba(59, 184, 154, 0.15);
        }
        
        .tx-icon.fund {
            background: rgba(74, 158, 221, 0.15);
        }
        
        .tx-icon.vote {
            background: rgba(232, 201, 106, 0.2);
        }
        
        .tx-info {
            flex: 1;
        }
        
        .tx-title {
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text);
        }
        
        .tx-hash {
            font-size: 0.75rem;
            color: var(--text-soft);
            font-family: monospace;
        }
        
        .tx-amount {
            font-size: 0.9rem;
            font-weight: 600;
        }
        
        .tx-amount.positive {
            color: var(--mint-dark);
        }
        
        .tx-amount.neutral {
            color: var(--blue-deep);
        }
        
        .tx-time {
            font-size: 0.75rem;
            color: var(--text-soft);
            text-align: right;
        }
        /* DAO SECTION */
        
        .dao-section {
            margin-bottom: 48px;
        }
        
        .dao-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 16px;
        }
        
        .vote-card {
            background: var(--glass-strong);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 22px;
            transition: all 0.25s;
        }
        
        .vote-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }
        
        .vote-title {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 6px;
        }
        
        .vote-desc {
            font-size: 0.8rem;
            color: var(--text-soft);
            margin-bottom: 14px;
            line-height: 1.5;
        }
        
        .vote-bar-wrap {
            margin-bottom: 12px;
        }
        
        .vote-labels {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            color: var(--text-soft);
            margin-bottom: 5px;
        }
        
        .vote-bar-track {
            height: 6px;
            border-radius: 3px;
            background: rgba(74, 158, 221, 0.15);
            overflow: hidden;
        }
        
        .vote-bar-fill {
            height: 100%;
            border-radius: 3px;
            background: linear-gradient(90deg, var(--blue), var(--mint-dark));
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .vote-actions {
            display: flex;
            gap: 8px;
        }
        
        .vote-yes {
            flex: 1;
            padding: 7px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            background: rgba(59, 184, 154, 0.12);
            color: var(--mint-dark);
            border: 1px solid rgba(59, 184, 154, 0.3);
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .vote-yes:hover {
            background: rgba(59, 184, 154, 0.22);
        }
        
        .vote-no {
            flex: 1;
            padding: 7px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            background: rgba(255, 100, 100, 0.08);
            color: #e05050;
            border: 1px solid rgba(255, 100, 100, 0.2);
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .vote-no:hover {
            background: rgba(255, 100, 100, 0.15);
        }
        /* MODAL */
        
        .modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 300;
            background: rgba(26, 35, 50, 0.4);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            display: grid;
            place-items: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }
        
        .modal-overlay.open {
            opacity: 1;
            pointer-events: all;
        }
        
        .modal {
            background: rgba(250, 248, 244, 0.98);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 36px;
            width: 480px;
            max-width: 90vw;
            box-shadow: var(--shadow-lg);
            transform: scale(0.95) translateY(20px);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .modal-overlay.open .modal {
            transform: scale(1) translateY(0);
        }
        
        .modal-title {
            font-family: 'DM Serif Display', serif;
            font-size: 1.4rem;
            color: var(--text);
            margin-bottom: 24px;
        }
        
        .form-row {
            margin-bottom: 16px;
        }
        
        .form-label {
            font-size: 0.78rem;
            font-weight: 500;
            color: var(--text-mid);
            margin-bottom: 5px;
            display: block;
        }
        
        .form-input {
            width: 100%;
            padding: 10px 14px;
            border-radius: 10px;
            background: var(--glass-strong);
            border: 1px solid var(--border);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.875rem;
            color: var(--text);
            transition: all 0.2s;
            outline: none;
        }
        
        .form-input:focus {
            border-color: rgba(74, 158, 221, 0.5);
            box-shadow: 0 0 0 3px rgba(74, 158, 221, 0.1);
        }
        
        .milestone-builder {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-top: 8px;
        }
        
        .ms-builder-row {
            display: flex;
            gap: 8px;
        }
        
        .ms-builder-row .form-input {
            flex: 1;
        }
        
        .add-ms-btn {
            padding: 8px 14px;
            border-radius: 8px;
            font-size: 0.8rem;
            font-weight: 500;
            background: rgba(74, 158, 221, 0.1);
            color: var(--blue-deep);
            border: 1px dashed rgba(74, 158, 221, 0.4);
            cursor: pointer;
            transition: all 0.2s;
            margin-top: 4px;
            width: 100%;
        }
        
        .add-ms-btn:hover {
            background: rgba(74, 158, 221, 0.18);
        }
        
        .modal-actions {
            display: flex;
            gap: 10px;
            margin-top: 24px;
        }
        
        .wallet-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 14px;
            border-radius: 10px;
            background: rgba(59, 184, 154, 0.1);
            border: 1px solid rgba(59, 184, 154, 0.25);
            font-size: 0.8rem;
            color: var(--mint-dark);
            font-weight: 500;
            margin-bottom: 24px;
        }
        
        .wallet-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: var(--mint-dark);
            animation: pulse 2s infinite;
        }
        /* NOTIFICATION */
        
        .notif {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 500;
            padding: 14px 20px;
            border-radius: 12px;
            background: var(--glass-strong);
            border: 1px solid var(--border);
            backdrop-filter: blur(20px);
            box-shadow: var(--shadow-lg);
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--text);
            display: flex;
            align-items: center;
            gap: 10px;
            transform: translateY(80px) scale(0.95);
            opacity: 0;
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .notif.show {
            transform: translateY(0) scale(1);
            opacity: 1;
        }
        
        .notif-icon {
            font-size: 16px;
        }
        /* TABS */
        
        .tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 28px;
            background: var(--glass);
            padding: 4px;
            border-radius: 12px;
            width: fit-content;
            border: 1px solid var(--border);
        }
        
        .tab-btn {
            padding: 8px 20px;
            border-radius: 9px;
            font-size: 0.85rem;
            font-weight: 500;
            border: none;
            cursor: pointer;
            transition: all 0.2s;
            color: var(--text-mid);
            background: transparent;
        }
        
        .tab-btn.active {
            background: white;
            color: var(--text);
            box-shadow: 0 2px 10px rgba(45, 127, 196, 0.12);
        }
        /* DASHBOARD */
        
        .dashboard-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
            margin-bottom: 32px;
        }
        
        .dash-card {
            background: var(--glass-strong);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 20px;
            backdrop-filter: blur(16px);
        }
        
        .dash-card-label {
            font-size: 0.78rem;
            color: var(--text-soft);
            font-weight: 500;
            margin-bottom: 8px;
        }
        
        .dash-card-value {
            font-family: 'DM Serif Display', serif;
            font-size: 1.8rem;
            color: var(--text);
        }
        
        .dash-card-sub {
            font-size: 0.78rem;
            color: var(--text-soft);
            margin-top: 2px;
        }
        
        .chart-bars {
            display: flex;
            align-items: flex-end;
            gap: 6px;
            height: 80px;
            margin-top: 12px;
        }
        
        .chart-bar {
            flex: 1;
            border-radius: 4px 4px 0 0;
            background: linear-gradient(180deg, var(--blue), rgba(74, 158, 221, 0.3));
            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            cursor: pointer;
        }
        
        .chart-bar:hover {
            opacity: 0.8;
        }
        /* ALGO BADGE */
        
        .algo {
            font-size: 0.7rem;
            color: var(--text-soft);
            font-weight: 400;
        }
        
        .responsive-table {
            overflow-x: auto;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th {
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-soft);
            text-align: left;
            padding: 10px 14px;
            border-bottom: 1px solid var(--border);
        }
        
        td {
            font-size: 0.82rem;
            color: var(--text-mid);
            padding: 12px 14px;
            border-bottom: 1px solid rgba(74, 158, 221, 0.08);
        }
        
        tr:hover td {
            background: rgba(74, 158, 221, 0.04);
        }
        
        @media (max-width:640px) {
            nav {
                padding: 14px 20px;
            }
            .hero {
                padding: 50px 20px 40px;
            }
            .stats-bar {
                padding: 0 20px;
                flex-direction: column;
            }
            .stat-item:first-child,
            .stat-item:last-child {
                border-radius: 0;
            }
            .main {
                padding: 0 20px 60px;
            }
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
            .side-panel {
                width: 100vw;
            }
        }
        
        .fade-in {
            animation: fadeUp 0.5s ease forwards;
            opacity: 0;
        }
        
        @keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px)
            }
            to {
                opacity: 1;
                transform: translateY(0)
            }
        }
        
        .stagger-1 {
            animation-delay: 0.05s;
        }
        
        .stagger-2 {
            animation-delay: 0.1s;
        }
        
        .stagger-3 {
            animation-delay: 0.15s;
        }
        
        .stagger-4 {
            animation-delay: 0.2s;
        }
        
        .stagger-5 {
            animation-delay: 0.25s;
        }
        
        .loading {
            opacity: 0.6;
            pointer-events: none;
        }
        
        .error-msg {
            color: #e05050;
            font-size: 0.8rem;
            margin-top: 4px;
        }
    </style>
</head>

<body>

    <!-- NAV -->
    <nav>
        <a class="logo" href="#">
            <div class="logo-icon">🔗</div>
            GrantFlow
        </a>
        <div class="nav-links">
            <button class="nav-link active" onclick="showTab('grants')">Grants</button>
            <button class="nav-link" onclick="showTab('dashboard')">Dashboard</button>
            <button class="nav-link" onclick="showTab('transactions')">Transactions</button>
        </div>
        <div style="display:flex; gap:12px">
            <button class="wallet-btn" id="wallet-btn" onclick="connectWallet()">Connect Wallet</button>
            <button class="nav-cta" onclick="openCreateModal()" id="create-btn">＋ New Grant</button>
        </div>
    </nav>

    <!-- HERO -->
    <div class="hero fade-in">
        <div class="hero-tag"><span></span> Powered by Algorand Blockchain</div>
        <h1>Transparent <em>Grant Funding</em><br/>for Student Projects</h1>
        <p>Milestone-based fund disbursement with full on-chain transparency. Every allocation, approval, and transaction recorded immutably on the Algorand blockchain.</p>
        <div class="hero-actions">
            <button class="btn-primary" onclick="openCreateModal()">Create a Grant</button>
            <button class="btn-secondary" onclick="showTab('dashboard')">View Dashboard</button>
        </div>
    </div>

    <!-- STATS BAR -->
    <div class="stats-bar fade-in stagger-1">
        <div class="stat-item">
            <div class="stat-val" id="stat-allocated">₳ 0</div>
            <div class="stat-label">Total Funds Allocated</div>
        </div>
        <div class="stat-item">
            <div class="stat-val" id="stat-active">0</div>
            <div class="stat-label">Active Grants</div>
        </div>
        <div class="stat-item">
            <div class="stat-val" id="stat-completed">0</div>
            <div class="stat-label">Milestones Completed</div>
        </div>
        <div class="stat-item">
            <div class="stat-val">98.2%</div>
            <div class="stat-label">Funds Accountability</div>
        </div>
    </div>

    <!-- MAIN -->
    <div class="main">

        <!-- GRANTS TAB -->
        <div id="tab-grants">
            <div class="grants-section">
                <div class="section-title fade-in stagger-2">Active Grants</div>
                <div class="section-sub fade-in stagger-2">Click any grant to view milestones and approve funds on-chain</div>
                <div class="grants-grid" id="grants-grid"></div>
            </div>
        </div>

        <!-- DASHBOARD TAB -->
        <div id="tab-dashboard" style="display:none">
            <div class="section-title fade-in">Funding Dashboard</div>
            <div class="section-sub fade-in">Real-time overview of all grant activity on App ID 1001</div>

            <div class="wallet-badge fade-in" id="wallet-badge-main" style="display:none">
                <div class="wallet-dot"></div>
                <span id="wallet-address-text">Connected: ALGO...XXXX · Balance: ₳ 0</span>
            </div>

            <div class="dashboard-grid fade-in">
                <div class="dash-card">
                    <div class="dash-card-label">TOTAL DISBURSED</div>
                    <div class="dash-card-value" id="dash-disbursed">₳ 0</div>
                    <div class="dash-card-sub" id="dash-disbursed-sub">+₳ 0 this month</div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-label">IN ESCROW</div>
                    <div class="dash-card-value" id="dash-escrow">₳ 0</div>
                    <div class="dash-card-sub" id="dash-escrow-sub">Pending milestones</div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-label">MONTH APPROVALS</div>
                    <div class="dash-card-value" id="dash-approvals">0</div>
                    <div class="dash-card-sub">Milestone approvals</div>
                    <div class="chart-bars" id="monthly-chart"></div>
                </div>
                <div class="dash-card">
                    <div class="dash-card-label">SUCCESS RATE</div>
                    <div class="dash-card-value">--</div>
                    <div class="dash-card-sub">Based on completion</div>
                </div>
            </div>

            <div class="section-title" style="margin-bottom:14px">All Grants Overview</div>
            <div class="responsive-table">
                <table id="grants-table">
                    <thead>
                        <tr>
                            <th>Grant Title</th>
                            <th>Team</th>
                            <th>Total</th>
                            <th>Released</th>
                            <th>Progress</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody id="grants-table-body"></tbody>
                </table>
            </div>
        </div>

        <!-- TRANSACTIONS TAB -->
        <div id="tab-transactions" style="display:none">
            <div class="tx-section">
                <div class="section-title fade-in">Transaction Feed</div>
                <div class="section-sub fade-in">Live on-chain activity across all grants on Algorand</div>
                <div class="tx-list" id="tx-list"></div>
            </div>
        </div>

    </div>

    <!-- SIDE PANEL -->
    <div class="panel-overlay" id="panel-overlay" onclick="closePanel()"></div>
    <div class="side-panel" id="side-panel">
        <button class="panel-close" onclick="closePanel()">✕</button>
        <div id="panel-content"></div>
    </div>

    <!-- CREATE MODAL -->
    <div class="modal-overlay" id="modal-overlay">
        <div class="modal">
            <div class="modal-title">Create New Grant</div>
            <div class="form-row">
                <label class="form-label">Grant Title</label>
                <input class="form-input" id="f-title" placeholder="e.g. AI Health Monitor App" />
            </div>
            <div class="form-row">
                <label class="form-label">Team / Student Name</label>
                <input class="form-input" id="f-team" placeholder="e.g. Team Nova" />
            </div>
            <div class="form-row">
                <label class="form-label">Total Amount (ALGO)</label>
                <input class="form-input" id="f-amount" type="number" placeholder="5000" />
            </div>
            <div class="form-row">
                <label class="form-label">Milestones</label>
                <div class="milestone-builder" id="ms-builder">
                    <div class="ms-builder-row">
                        <input class="form-input" placeholder="Milestone name" value="Prototype" />
                        <input class="form-input" style="max-width:100px" placeholder="ALGO" value="1500" />
                    </div>
                    <div class="ms-builder-row">
                        <input class="form-input" placeholder="Milestone name" value="MVP Launch" />
                        <input class="form-input" style="max-width:100px" placeholder="ALGO" value="2000" />
                    </div>
                    <div class="ms-builder-row">
                        <input class="form-input" placeholder="Milestone name" value="Final Review" />
                        <input class="form-input" style="max-width:100px" placeholder="ALGO" value="1500" />
                    </div>
                </div>
                <button class="add-ms-btn" onclick="addMilestoneRow()">+ Add Milestone</button>
            </div>
            <div id="modal-error" class="error-msg"></div>
            <div class="modal-actions">
                <button class="btn-primary" style="flex:1" id="deploy-btn" onclick="createGrant()">Deploy to App ID 1001</button>
                <button class="btn-secondary" onclick="closeModal()">Cancel</button>
            </div>
        </div>
    </div>

    <!-- NOTIFICATION -->
    <div class="notif" id="notif">
        <span class="notif-icon">✅</span>
        <span id="notif-text">Transaction confirmed</span>
    </div>

    <script>
        // ==================== ALGORAND CONFIG ====================
        const ALGORAND_CONFIG = {
            server: 'http://localhost:4001',
            token: 'aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa',
            port: 4001,
            appId: 1001
        };

        let algodClient = null;
        let walletAddress = null;
        let walletBalance = 0;

        // ==================== DATA ====================
        const grantsData = [{
            id: 1,
            title: "AI Health Monitor App",
            team: "Team Nova",
            amount: 8000,
            released: 5500,
            status: "active",
            appId: null,
            milestones: [{
                name: "Requirements & Design",
                amount: 1500,
                status: "done",
                date: "Jan 10"
            }, {
                name: "Prototype Build",
                amount: 2000,
                status: "done",
                date: "Feb 5"
            }, {
                name: "Beta Testing",
                amount: 2500,
                status: "current",
                date: "Mar 15"
            }, {
                name: "Final Deployment",
                amount: 2000,
                status: "pending",
                date: "Apr 20"
            }, ]
        }, {
            id: 2,
            title: "Blockchain Supply Chain",
            team: "DataSync Labs",
            amount: 12000,
            released: 4000,
            status: "active",
            appId: null,
            milestones: [{
                name: "Architecture Design",
                amount: 2000,
                status: "done",
                date: "Jan 20"
            }, {
                name: "Smart Contract Dev",
                amount: 2000,
                status: "done",
                date: "Feb 28"
            }, {
                name: "Integration Layer",
                amount: 3000,
                status: "current",
                date: "Mar 22"
            }, {
                name: "Frontend Dashboard",
                amount: 2500,
                status: "pending",
                date: "Apr 30"
            }, {
                name: "Audit & Launch",
                amount: 2500,
                status: "pending",
                date: "May 20"
            }, ]
        }, {
            id: 3,
            title: "AR Campus Navigation",
            team: "XR Builders",
            amount: 6500,
            released: 6500,
            status: "completed",
            appId: null,
            milestones: [{
                name: "UX Research",
                amount: 1000,
                status: "done",
                date: "Oct 5"
            }, {
                name: "AR Prototype",
                amount: 2000,
                status: "done",
                date: "Nov 2"
            }, {
                name: "Campus Mapping",
                amount: 2000,
                status: "done",
                date: "Nov 28"
            }, {
                name: "App Release",
                amount: 1500,
                status: "done",
                date: "Dec 15"
            }, ]
        }];

        const txData = [{
            type: "release",
            icon: "💸",
            title: "Milestone Approved: Beta Testing",
            project: "AI Health Monitor",
            amount: "+₳ 2,500",
            hash: "TXN-a4f8...2e9c",
            time: "2 min ago"
        }, {
            type: "fund",
            icon: "🏦",
            title: "Grant Deployed",
            project: "Blockchain Supply Chain",
            amount: "₳ 12,000",
            hash: "TXN-b9d1...7a3f",
            time: "18 min ago"
        }, {
            type: "release",
            icon: "💸",
            title: "Milestone Approved: Smart Contract Dev",
            project: "Blockchain Supply Chain",
            amount: "+₳ 2,000",
            hash: "TXN-c2e4...1b6d",
            time: "1 hr ago"
        }, ];

        // ==================== INIT ====================
        async function init() {
            try {
                algodClient = new algosdk.Algodv2(ALGORAND_CONFIG.token, ALGORAND_CONFIG.server, ALGORAND_CONFIG.port);

                // Test connection
                const status = await algodClient.status().do();
                notify(`✅ Connected to Algorand (round ${status['last-round']})`);
                console.log('AlgoKit LocalNet status:', status);
            } catch (err) {
                console.error('Failed to connect to Algorand:', err);
                notify(`❌ Cannot connect to Algorand at ${ALGORAND_CONFIG.server}`);
            }

            renderGrants();
            updateStats();
        }

        // ==================== WALLET ====================
        async function connectWallet() {
            const address = prompt('Enter your Algorand address (or leave blank for demo):');

            if (address) {
                try {
                    const accountInfo = await algodClient.accountInformation(address).do();
                    walletAddress = address;
                    walletBalance = accountInfo.amount / 1e6; // Convert from microAlgos

                    updateWalletDisplay();
                    notify(`✅ Connected: ${address.slice(0,10)}...${address.slice(-6)}`);
                } catch (err) {
                    notify(`❌ Account not found: ${err.message}`);
                }
            } else {
                // Demo mode
                walletAddress = 'DEMO' + Math.random().toString(36).substr(2, 9).toUpperCase();
                walletBalance = 12450;
                updateWalletDisplay();
                notify(`🎭 Demo mode enabled`);
            }
        }

        function updateWalletDisplay() {
            const btn = document.getElementById('wallet-btn');
            btn.textContent = `${walletAddress.slice(0,10)}...${walletAddress.slice(-6)}`;
            btn.classList.add('connected');

            const badge = document.getElementById('wallet-badge-main');
            badge.style.display = 'flex';
            document.getElementById('wallet-address-text').textContent =
                `Connected: ${walletAddress.slice(0,10)}...${walletAddress.slice(-6)} · Balance: ₳ ${walletBalance.toLocaleString()}`;
        }

        // ==================== RENDER ====================
        function renderGrants() {
            const grid = document.getElementById('grants-grid');
            grid.innerHTML = grantsData.map((g, i) => {
                const doneCount = g.milestones.filter(m => m.status === 'done').length;
                const pct = Math.round((g.released / g.amount) * 100);
                const dots = g.milestones.map(m => `<div class="ms-dot ${m.status}"></div>`).join('');
                const badgeClass = {
                    active: 'badge-active',
                    pending: 'badge-pending',
                    completed: 'badge-completed'
                }[g.status];
                const badgeText = {
                    active: 'Active',
                    pending: 'Pending',
                    completed: 'Completed'
                }[g.status];
                return `<div class="grant-card fade-in stagger-${(i%5)+1}" onclick="openGrant(${g.id})">
      <div class="grant-header">
        <span class="grant-badge ${badgeClass}">${badgeText}</span>
        <span class="grant-amount">₳ ${g.amount.toLocaleString()} <span class="algo">ALGO</span></span>
      </div>
      <div class="grant-title">${g.title}</div>
      <div class="grant-team">👥 ${g.team} · ${doneCount}/${g.milestones.length} milestones</div>
      <div class="milestones-mini">${dots}</div>
      <div class="grant-footer">
        <div class="grant-progress-text"><strong>${pct}%</strong> released (₳ ${g.released.toLocaleString()})</div>
        <button class="grant-action">View →</button>
      </div>
    </div>`;
            }).join('');
        }

        function renderTx() {
            document.getElementById('tx-list').innerHTML = txData.map(t => `
    <div class="tx-row fade-in">
      <div class="tx-icon ${t.type}">${t.icon}</div>
      <div class="tx-info">
        <div class="tx-title">${t.title}</div>
        <div class="tx-hash">${t.project} · ${t.hash}</div>
      </div>
      <div>
        <div class="tx-amount ${t.type==='release'?'positive':'neutral'}">${t.amount}</div>
        <div class="tx-time">${t.time}</div>
      </div>
    </div>
  `).join('');
        }

        function renderDashboard() {
            const tb = document.getElementById('grants-table-body');
            tb.innerHTML = grantsData.map(g => {
                const pct = Math.round((g.released / g.amount) * 100);
                const done = g.milestones.filter(m => m.status === 'done').length;
                return `<tr>
      <td><strong style="color:var(--text)">${g.title}</strong></td>
      <td>${g.team}</td>
      <td>₳ ${g.amount.toLocaleString()}</td>
      <td style="color:var(--mint-dark)">₳ ${g.released.toLocaleString()}</td>
      <td>${done}/${g.milestones.length}</td>
      <td><span class="grant-badge badge-${g.status}" style="font-size:0.7rem">${g.status}</span></td>
    </tr>`;
            }).join('');

            const heights = [35, 55, 40, 70, 60, 80, 65];
            const chart = document.getElementById('monthly-chart');
            chart.innerHTML = heights.map((h) => `<div class="chart-bar" style="height:${h}px"></div>`).join('');
        }

        function updateStats() {
            const totalAllocated = grantsData.reduce((sum, g) => sum + g.amount, 0);
            const activeCount = grantsData.filter(g => g.status === 'active').length;
            const completedMilestones = grantsData.reduce((sum, g) =>
                sum + g.milestones.filter(m => m.status === 'done').length, 0
            );

            document.getElementById('stat-allocated').textContent = `₳ ${totalAllocated.toLocaleString()}`;
            document.getElementById('stat-active').textContent = activeCount;
            document.getElementById('stat-completed').textContent = completedMilestones;

            // Dashboard
            const disbursed = grantsData.reduce((sum, g) => sum + g.released, 0);
            const escrow = totalAllocated - disbursed;

            document.getElementById('dash-disbursed').textContent = `₳ ${disbursed.toLocaleString()}`;
            document.getElementById('dash-escrow').textContent = `₳ ${escrow.toLocaleString()}`;
            document.getElementById('dash-approvals').textContent = completedMilestones;
        }

        // ==================== UI INTERACTIONS ====================
        function showTab(tab) {
            ['grants', 'dashboard', 'transactions'].forEach(t => {
                document.getElementById('tab-' + t).style.display = t === tab ? 'block' : 'none';
            });
            document.querySelectorAll('.nav-link').forEach((b, i) => {
                b.classList.toggle('active', ['grants', 'dashboard', 'transactions'][i] === tab);
            });
            if (tab === 'dashboard') renderDashboard();
            if (tab === 'transactions') renderTx();
        }

        function openGrant(id) {
            const g = grantsData.find(x => x.id === id);
            const pct = Math.round((g.released / g.amount) * 100);
            const msHtml = g.milestones.map((m, i) => `
    <div class="milestone-row ${m.status}">
      <div class="ms-icon ${m.status}">${m.status==='done'?'✓':m.status==='current'?'⏳':'○'}</div>
      <div class="ms-info">
        <div class="ms-name">${m.name}</div>
        <div class="ms-date">${m.date}</div>
      </div>
      <div class="ms-amount">₳ ${m.amount.toLocaleString()}</div>
      ${m.status==='current'?`<button class="approve-btn" onclick="approveMilestone(${id},${i})" ${!walletAddress?'disabled':''}>Approve</button>`:''}
    </div>
  `).join('');

  document.getElementById('panel-content').innerHTML = `
    <div class="panel-title">${g.title}</div>
    <div class="panel-sub">👥 ${g.team} · App ID: ${g.appId || ALGORAND_CONFIG.appId}</div>
    <div class="panel-amount-block">
      <div>
        <div style="font-size:0.75rem;color:var(--text-soft);margin-bottom:4px">GRANT TOTAL</div>
        <div class="panel-amount">₳ ${g.amount.toLocaleString()}</div>
      </div>
      <div style="text-align:right">
        <div class="panel-released">Released: <strong>₳ ${g.released.toLocaleString()}</strong></div>
        <div class="panel-released">In Escrow: <strong style="color:var(--blue)">₳ ${(g.amount-g.released).toLocaleString()}</strong></div>
        <div style="font-size:1.2rem;font-weight:600;color:var(--text);margin-top:4px">${pct}%</div>
      </div>
    </div>
    <div style="font-size:0.82rem;font-weight:600;color:var(--text-mid);margin-bottom:10px">MILESTONES</div>
    <div class="milestones-list">${msHtml}</div>
    <div style="font-size:0.75rem;color:var(--text-soft);padding:12px;background:rgba(74,158,221,0.06);border-radius:10px;border:1px solid var(--border)">
      🔒 Funds held in smart contract escrow. Released upon approval.
    </div>
  `;

  document.getElementById('panel-overlay').classList.add('open');
  document.getElementById('side-panel').classList.add('open');
}

function closePanel() {
  document.getElementById('panel-overlay').classList.remove('open');
  document.getElementById('side-panel').classList.remove('open');
}

function approveMilestone(grantId, msIdx) {
  if (!walletAddress) {
    notify('❌ Connect wallet first');
    return;
  }

  const g = grantsData.find(x=>x.id===grantId);
  const ms = g.milestones[msIdx];
  
  ms.status = 'done';
  g.released += ms.amount;
  const next = g.milestones[msIdx+1];
  if(next) next.status = 'current';
  else g.status = 'completed';

  openGrant(grantId);
  renderGrants();
  updateStats();
  
  txData.unshift({
    type:"release", icon:"💸", 
    title:`Milestone Approved: ${ms.name}`, 
    project:g.title, 
    amount:"+₳ " + ms.amount.toLocaleString(), 
    hash:"TXN-" + Math.random().toString(36).substr(2, 8), 
    time:"just now"
  });
  
  notify(`✅ ₳ ${ms.amount.toLocaleString()} released for "${ms.name}"`);
}

// ==================== CREATE GRANT ====================
function openCreateModal() {
  if (!walletAddress) {
    notify('⚠️ Connect wallet to create grants');
    return;
  }
  document.getElementById('modal-overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('modal-overlay').classList.remove('open');
  document.getElementById('modal-error').innerHTML = '';
}

document.getElementById('modal-overlay').addEventListener('click', e=>{
  if(e.target === document.getElementById('modal-overlay')) closeModal();
});

function addMilestoneRow() {
  const row = document.createElement('div');
  row.className='ms-builder-row';
  row.innerHTML=`<input class="form-input" placeholder="Milestone name"/>
  <input class="form-input" style="max-width:100px" placeholder="ALGO"/>`;
  document.getElementById('ms-builder').appendChild(row);
}

function createGrant() {
  const title = document.getElementById('f-title').value || 'New Grant';
  const team = document.getElementById('f-team').value || 'Student Team';
  const amount = parseInt(document.getElementById('f-amount').value) || 5000;

  const rows = document.querySelectorAll('#ms-builder .ms-builder-row');
  const milestones = Array.from(rows).map((r,i)=>{
    const inputs = r.querySelectorAll('input');
    return {
      name: inputs[0].value || `Milestone ${i+1}`,
      amount: parseInt(inputs[1].value)||1000,
      status: i===0?'current':'pending',
      date:'TBD'
    };
  });

  const msTotal = milestones.reduce((sum, m) => sum + m.amount, 0);
  if (msTotal !== amount) {
    document.getElementById('modal-error').innerHTML = 
      `❌ Milestone total (₳${msTotal}) must equal grant amount (₳${amount})`;
    return;
  }

  const newGrant = {
    id: grantsData.length+1, title, team, amount,
    released:0, status:'active', appId: ALGORAND_CONFIG.appId, milestones
  };

  grantsData.unshift(newGrant);
  
  txData.unshift({
    type:"fund", icon:"🏦", 
    title:`Grant Deployed: ${title}`, 
    project:team, 
    amount:"₳ " + amount.toLocaleString(), 
    hash:"TXN-" + Math.random().toString(36).substr(2, 8), 
    time:"just now"
  });

  renderGrants();
  updateStats();
  closeModal();
  
  // Clear form
  document.getElementById('f-title').value = '';
  document.getElementById('f-team').value = '';
  document.getElementById('f-amount').value = '';
  
  notify(`🚀 Grant "${title}" deployed to App ID ${ALGORAND_CONFIG.appId}`);
}

// ==================== NOTIFICATIONS ====================
function notify(msg) {
  const el = document.getElementById('notif');
  document.getElementById('notif-text').textContent = msg;
  el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'), 3500);
}

// ==================== STARTUP ====================
window.addEventListener('load', init);
    </script>
</body>

</html>